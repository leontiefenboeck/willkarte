{
  "manifest_version": 3,
  "name": "willkarte",
  "version": "1.0.1",
  "description": "Shows willhaben.at real estate search results on an interactive map with price markers.",
  "host_permissions": ["https://www.willhaben.at/*"],
  "content_scripts": [
    {
      "matches": ["https://www.willhaben.at/iad/immobilien/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["map.html", "map.js", "vendor/*"],
      "matches": ["https://www.willhaben.at/*"]
    }
  ]
}